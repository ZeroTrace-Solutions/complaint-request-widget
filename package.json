{
  "name": "@zerotrace-solutions/complaint-request-widget",
  "version": "0.6.0",
  "description": "Floating complaint and support widget for Tailwind + shadcn React apps.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./locales": {
      "types": "./dist/locales.d.ts",
      "import": "./dist/locales.js",
      "require": "./dist/locales.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "complaint-request-widget": "dist/cli.cjs"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cli-e2e": "npm run build && vitest run tests/cli-binary.test.ts",
    "smoke:consumer": "node ./scripts/smoke-pack.mjs",
    "version:auto": "node ./scripts/bump-release-version.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "npm run build"
  },
  "keywords": [
    "react",
    "widget",
    "complaint",
    "tailwind",
    "shadcn",
    "i18n"
  ],
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZeroTrace-Solutions/complaint-request-widget.git"
  },
  "bugs": {
    "url": "https://github.com/ZeroTrace-Solutions/complaint-request-widget/issues"
  },
  "homepage": "https://github.com/ZeroTrace-Solutions/complaint-request-widget#readme",
  "peerDependencies": {
    "framer-motion": ">=11",
    "lucide-react": ">=0.450.0",
    "react": ">=18",
    "react-dom": ">=18",
    "react-i18next": ">=15"
  },
  "dependencies": {
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^24.4.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "framer-motion": "^12.23.22",
    "lucide-react": "^0.542.0",
    "rimraf": "^6.0.1",
    "react-i18next": "^16.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
